# requires index
# sets page_alias
function find_index_alias {
	page_alias=

	if [ "$1" = "0" ]
	then
		return 0
	fi
	
	local alias_file=
	local alias=
	local location=
	local sourcefile=
	local entry=
	for entry in ${1//./ }
	do
		((entry++))
		if [ "$entry" = "0" ]
		then
			tput setaf $SEVERITY_HIGH
			echo "invalid index number: $1 => $location"
			tput sgr0
			return 1
		fi

		if [ -z "$location" ]
		then
			sourcefile="$(sed -n "${entry}p" ".index")"
			location="${sourcefile%% *}"
		else
			sourcefile="$(sed -n "${entry}p" "${location}/.index")"
			location="${location}/${sourcefile%% *}"
		fi

		if [ -d "$location" ]
		then
			alias_file="${location}/README.alias.txt"
		elif [ -f "$location" ]
		then
			if [ "$entry" = "1" ]
			then
				continue
			fi
			alias_file="${location%.*}.alias.txt"
		else
			tput setaf $SEVERITY_HIGH
			echo "invalid index for aliasing: ${1} => ${location}"
			tput sgr0
			return 1
		fi

		if [ -f "$alias_file" ] && [ "$(wc -m < "$alias_file")" -gt 0 ]
		then
			alias="${alias}/$(cat "$alias_file")"

			if [ "$entry" = "0" ]
			then
				alias="${alias}/index"
			fi
		else
			return 1
		fi
	done

	page_alias="$alias"
}

# requires absolute path to page
function generate_quick_access_section {
	local page="${1%.*}"
	page="${page##*/}"
	local current_index=
	local next_index=
	local previous_index=
	local button=

	index_page "$1"
	current_index="$page_index"

	nearest_path "$1" up
	if [ "$page_index" = "$current_index" ]
	then
		previous_index=
	else
		previous_index="$page_index"
	fi

	nearest_path "$1" down
	if [ "$page_index" = "$previous_index" ]
	then
		next_index=
	else
		next_index="$page_index"
	fi

	generate_html_list begin pager

	find_index_alias "${previous_index:-0}"

	button="previous page"
	if [ -n "$previous_index" ]
	then
		previous_index="${previous_index}.html"
		generate_html_item_with_link "$button" "${page_alias:-$previous_index}" previous "B"
	else
		generate_html_item_with_link "$button" "#" "previous disabled"
	fi

	button="top page"
	if [ -z "$previous_index" ] || [ -z "$next_page" ]
	then
		generate_html_item_with_link "$button" "/" top "T"
	fi

	find_index_alias "${next_index:-0}"

	button="next page"
	if [ -n "$next_index" ]
	then
		next_index="${next_index}.html"
		generate_html_item_with_link "$button" "${page_alias:-$next_index}" next "F"
	else
		generate_html_item_with_link "$button" "#" "next disabled"
	fi

	generate_html_list end
}

function generate_table_of_content {
	local hierarchy="${1%/*}"
	local heading="${2:-false}"
	local nest="${3:-1}"
	local entry=
	local indentation=
	local local_index=
	local title=
	local page_link=

	while read -r entry
	do
		entry="${entry%% *}"
		if [ -d "${hierarchy}/${entry}" ] || [ "$entry" = "README.md" ]
		then
			if [ "$entry" = "README.md" ]
			then
				index_page "${hierarchy}/${entry}"
				if [ "$page_index" = "0" ] || [ "$heading" == "true" ]
				then
					heading="false"
					#title="$(cat "${hierarchy}/${entry%.*}.title.txt")"
					#generate_html_header_with_link "$1" 3 "$title" "${page_index}.html"
					generate_html_breaker
					generate_html_header 3 "Table of Content"
					generate_list_group_root "$1" begin
				else
					badge=0
					generate_group_badge "$1"
					page_number="${page_index%.0}"
					page_number="${page_number##*.}"
					title="${page_number:-0}. $(cat "${hierarchy}/${entry%.*}.title.txt")"
					if [ "$nest" -gt 0 ]
					then
						generate_list_group_collapse_item "${page_index//./-}" "$title" "$badge"
					else
						page_link="${page_index}.html"
						find_index_alias "$page_index"
						generate_list_group_item "${page_alias:-$page_link}" "$title" "$nest" "$badge"
					fi
					generate_list_group "$1" begin "${page_index//./-}"
				fi
			elif [ -f "${hierarchy}/${entry%/}/.index" ]
			then
				if [ "$nest" -gt 0 ]
				then
					generate_table_of_content "${hierarchy}/${entry%/}/.index" "false" "$[nest - 1]"
					generate_list_group "$1" end
				fi
			else
				tput setaf $SEVERITY_HIGH
				echo "broken hierarchy in ${hierarchy}/${entry%/}/.index"
				tput sgr0
			fi
		elif ! [ -f "${hierarchy}/${entry}" ]
		then
			tput setaf $SEVERITY_HIGH
			echo "missing entry in table of content: ${hierarchy}/${entry}"
			tput sgr0
			return 1
		elif ! [ -f "${hierarchy}/${entry%.*}.title.txt" ]
		then
			tput setaf $SEVERITY_HIGH
			echo "missing entry title in table of content: ${hierarchy}/{$entry}"
			tput sgr0
			return 2
		else
			index_page "${hierarchy}/${entry}"
			page_number="${page_index%.0}"
			page_number="${page_number##*.}"
			title="${page_number:-0}. $(cat "${hierarchy}/${entry%.*}.title.txt")"
			page_link="${page_index}.html"
			find_index_alias "$page_index"
			generate_list_group_item "${page_alias:-$page_link}" "$title" "$nest"
		fi
	done < "${hierarchy}/.index"
}

# requires path to page
# requires index
function generate_alias {
	local path="${1%/}"
	local index="$2"

	if [ "$path" = "." ]
	then
		return 0
	fi
	
	local alias_file=
	local alias="html-files"
	local target=
	local location=
	local entry=
	for entry in ${1//\//$'\n'}
	do
		if [ -z "$location" ]
		then
			location="$entry"
			continue
		elif [ "$entry" = "." ]
		then
			location="./$entry"
			continue
		else
			location="${location}/${entry}"
		fi

		if [ -f "${location}" ]
		then
			alias_file="${location%.*}.alias.txt"
		elif [ -d "${location}" ]
		then
			alias_file="${location}/README.alias.txt"
			target="../${target}"
		else
			tput setaf $SEVERITY_HIGH
			echo "aliasing failed due to broken hierarchy: ${location}"
			tput sgr0
			return 1
		fi

		if [ -f "$alias_file" ] && [ "$(wc -m < "$alias_file")" -gt 0 ]
		then
			alias="${alias}/$(cat "$alias_file")"

			if [ -d "$location" ] && ! [ -d "$alias" ]
			then
				if ! mkdir "$alias"
				then
					tput setaf $SEVERITY_HIGH
					echo "cannot create alias directory: $alias"
					tput sgr0
					return 1
				fi
			fi

			if [ -d "$path" ] && [ "$path" == "$location" ]
			then
				alias="${alias}/index"
			fi
		else
			tput setaf $SEVERITY_MEDIUM
			echo "alias not found: ${path}"
			tput sgr0
			return 1
		fi
	done

	target="${target}${index}" # {../../../}{3.1.1.html}

	if ! [ -L "$alias" ] && ! ln -s "html-files/$index" "$alias"
	then
		tput setaf $SEVERITY_HIGH
		echo "Failed to create link for alias: $path"
		echo "  target: $target"
		echo "  alias: $alias"
		tput sgr0
		return 1
	fi
}

