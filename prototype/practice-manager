function usage {
	echo "Notebook Manager (Milestone)"
	echo
	tput setaf $SEVERITY_HIGH
	echo "Usage:"
	tput sgr0
	echo
	tput setaf 7
	echo " $ practice-manager [-f,--force] [-p,--preview] [-r,--remove] [-o,--reorder] <path>"
