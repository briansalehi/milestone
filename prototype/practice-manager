	generate_html_header 3 "Source"
	while [ $# -gt 0 ]
	do
		generate_page_name "${1}"

		local syntax=
		if [ -n "$SYNTAX" ]
		then
			syntax="$SYNTAX"
		else
			syntax="${1##*.}"
		fi

		generate_html_code begin "language-${syntax}" line-numbers
		OLD_IFS="$IFS"
