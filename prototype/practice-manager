# requires path to reference file
function inherit_references {
	local temp="$(mktemp)"
	local sorted="$(mktemp)"
	local stripped="$(mktemp)"

	local reference
	local reference_path
	local hierarchy="."
	for reference_path in ${1//\//$'\n'}
	do
		hierarchy="${hierarchy}/${reference_path}"

		if [ -d "$hierarchy" ]
		then
			reference="${hierarchy}/README.reference.txt"
			if [ -s "$reference" ]
			then
				cat "$reference" >> "$temp"
			fi
		fi
		unset reference_path
		unset reference
	done
	grep -v '^#' "$temp" | sed -e 's/:.*$//' | sort | uniq > "$sorted"
	sed 's/:.*$//' "$1" > "$stripped"
	grep -v -x -f "$stripped" "$sorted" | sort | uniq > "$temp"
	sed -i 's/^/#/' "$temp"
	if [ -s "$temp" ]
	then
		cat "$temp" "$1" | sort | uniq > "$sorted"
		mv "$sorted" "$1"
	fi
	rm -f "$temp" "$stripped" "$sorted"
}

