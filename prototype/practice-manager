# requires absolute path to page
function generate_configuration {
	local page

	if [ -f "$1" ]
	then
		page="${1%.*}.config"
	elif [ -d "$1" ]
	then
		page="${1%/}/.config"
	else
		tput setaf $SEVERITY_HIGH
		echo "invalid location to create config file: $1" >&2
		tput sgr0
		return 1
	fi

	echo "$main_configuration" > "$page"
}

# requires path to config
function regenerate_configuration {
	if [ "${1##*.}" != "config" ]
	then
		tput setaf $SEVERITY_HIGH
		echo "Invalid configuration to regenerate: $1" >&2
		tput sgr0
		return 1
	elif ! [ -f "$1" ]
	then
		touch "$1"
	fi

	update_configuration "${1%*/}"

	local target_config="$(grep '^[^# ]' "$1")"
	generate_configuration "$1"

	# backward compatibility section
	# if configs name are changed, map their values into new ones
	local line
	local config
	local value
	while read -r line
	do
		config="${line%%=*}" # read configuration name
		value="${line#*=}" # read configuration value
		value="${value%%#*}" # ignore inline comments in values

		case "$config" in
			GENERATES_ERROR) config="GENERATES_RUNTIME_ERROR" ;;
			LANGUAGE) config="SYNTAX" ;;
			OUTPUT_OBJECT) config="OBJECT_EXTENSION" ;;
			CHAPTER_TEMPLATE)
				if [ "${validation_check:-0}" == "202012271813" ] && [ "$(grep "toc" <<< "$value")" == "" ]
				then
					value="${value%\"} toc\""
				fi ;;
			COMPILATION_SCHEME)
				if [ -n "${COMPILATION_SCHEME:-}" ]
				then
					sed -i "/EXECUTION_SCHEME=/s/\(EXECUTION_SCHEME\)=\(.*\)/\1=\2;${value//\"/}/" "$1"
				fi
				;;
			POST_COMPILATION_SCHEME)
				if [ -n "${POST_COMPILATION_SCHEME:-}" ]
				then
					sed -i "/EXECUTION_SCHEME=/s/\(EXECUTION_SCHEME\)=\(.*\)/\1=\2;${value//\"/}/" "$1"
				fi
				;;
			LINKAGE_SCHEME)
				if [ -n "${LINKAGE_SCHEME:-}" ]
				then
					sed -i "/EXECUTION_SCHEME=/s/\(EXECUTION_SCHEME\)=\(.*\)/\1=\2;${value//\"/}/" "$1"
				fi
				;;
			RUNNING_SCHEME)
				if [ -n "${RUNNING_SCHEME:-}" ]
				then
					sed -i "/EXECUTION_SCHEME=/s/\(EXECUTION_SCHEME\)=\(.*\)/\1=\2;${value//\"/}/" "$1"
				fi
				;;
		esac

		sed -i "/^#${config}=/s/^#\(${config}\)=.*/\1=${value}/" "$1"
	done <<< "$target_config"

	sed -i \
		-e '/EXECUTION_SCHEME=/s/=\([^\"]\)/=\"\1/' \
		-e '/EXECUTION_SCHEME=/s/\([^=\"]\)$/\1\"/' \
		-e '/EXECUTION_SCHEME=/s/;;/;/g' \
		-e '/EXECUTION_SCHEME=/s/=";/="/' \
		"$1"

	if ! grep -wq '^#EXECUTION_SCHEME=$' "$1"
	then
		sed -i "/^#EXECUTION_SCHEME=/s/^#//" "$1"
	fi

	# update commented configuration values
	local line
	local config
	local value
	while read -r line
	do
		config="${line%%=*}" # read configuration name
		config="${config#\#}" # eliminate first # character
		value="${line#*=}" # read configuration value
		value="${value%%#*}" # ignore inline comments in values

		case "$config" in
			SYNTAX) value="\"$SYNTAX\"" ;;
			EXECUTION_SCHEME) value="\"$EXECUTION_SCHEME\"" ;;
			PAGE_TEMPLATE) value="\"$PAGE_TEMPLATE\"" ;;
			CHAPTER_TEMPLATE) value="\"$CHAPTER_TEMPLATE\"" ;;
			OBJECT_EXTENSION) value="$OBJECT_EXTENSION" ;;
			CAPTURE_SCREENSHOT) value="$CAPTURE_SCREENSHOT" ;;
			TECHNICAL_LEVEL) value="$TECHNICAL_LEVEL" ;;
		esac

		sed -i "/^#${config}=/s/^\(#${config}\)=.*/\1=${value}/" "$1"
	done <<< "$(grep '^#[A-Z]' "$1")"
}

# requires path to page
function validate_page {
	local page=
	local extension=

	for extension in alias.txt title.txt comment.txt reference.txt config
	do
		page="${1%.*}.${extension}"

		if ! [ -f "$page" ]
		then
			touch "$page"

			case "$extension" in
				config)
					generate_configuration "$1"
					regenerate_configuration "$page"
					;;
				reference.txt)
					inherit_references "$page"
					;;
			esac
		else
			case "$extension" in
				config)
					regenerate_configuration "$page"
					;;
				reference.txt)
					inherit_references "$page"
					;;
			esac
		fi
	done
}

# requires path to chapter
function validate_chapter {
	local page=
	local extension=

	if ! [ -f "${1%/}/.index" ]
	then
		echo "README.md" > "${1%/}/.index"
	elif [ "$(head -n1 "${1%/}/.index")" != "README.md" ]
	then
		sed -i -e '/README.md/d' -e '1i README.md' "${1%/}/.index"
	fi

	# update configuration of chapter
	regenerate_configuration "${1%/}/.config"

	for extension in md config alias.txt title.txt comment.txt reference.txt
	do
		page="${1%/}/README.${extension}"

		case "$extension" in
			config)
				# update configuration of readme
				regenerate_configuration "$page"
				;;
			reference.txt)
				if ! [ -f "$page" ]
				then
					touch "$page"
				fi
				inherit_references "$page"
				;;
			*)
				if ! [ -f "$page" ]
				then
					if [ "$extension" = "md" ]
					then
						echo -e "# Milestone Notebooks\n" > "$page"
						echo -n "This file is automatically created by " >> "$page"
						echo -n "<b>Milestone's Notebook Manager</b> " >> "$page"
						echo -n "and is part of the " >> "$page"
						echo -n "<a href=\"https://milextone.ir\">" >> "$page"
						echo -n "<b>Milestone</b></a> project." >> "$page"
					else
						touch "$page"
					fi
				fi
				;;
		esac
	done
}

# requires relative path to list
function validate_configuration {
	local directory="${1%/*}"
	local members
	local line
	local file

	if ! [ -f "$1" ]
	then
		tput setaf $SEVERITY_HIGH
		echo "Unindexed directory: $directory/" >&2
		tput sgr0
		return 1
	fi

	while read -r line
	do
		line="${line%% *}"
		if [ -f "$directory/$line" ]
		then
			validate_page "$directory/$line"
		elif [ -d "$directory/$line" ]
		then
			validate_chapter "$directory/$line"
			if ! validate_configuration "$directory/$line/.index"
			then
				return 1
			fi
		else
			tput setaf $SEVERITY_HIGH
			echo "Missing entry: $directory/$line" >&2
			tput sgr0
			return 1
		fi
	done < "$1"
}

# requires path to source
function update_configuration {
	local directory
	local config

	for level in ${1//\//$'\n'}
	do
		if [ -d "$directory$level" ]
		then
			directory="$directory$level/"
		elif [ -f "$directory$level" ]
		then
			directory="$directory${level%.*}"
		fi

		config="$directory.config"

		if [ -f "$config" ]
		then
			source "$config"
		fi
	done
}

# requires scheme
# requires page name
function create_command_scheme {
	local scheme="$1"
	local source="$2"
	local headers="$3"
	command_scheme=

	local component
	for component in $scheme
	do
		case "$component" in
			object) command_scheme+="${source%.*}${OBJECT_EXTENSION:-.o} " ;;
			source) command_scheme+="${source} " ;;
			input) command_scheme+="< ${source%.*}.input.txt ";;
			binary) command_scheme+="${source%.*}${EXECUTABLE_EXTENSION:-.bin} " ;;
			headers) command_scheme+="$headers " ;;
			page|pagename|rawname) command_scheme+="${source%.*} " ;;
			location) command_scheme+="${source%/*} " ;;
			makefile) local makefile="${source%.*}.make"; command_scheme+="${makefile##*/} " ;;
			extension-*) command_scheme+="${source%.*}.${component#extenion-} " ;;
			screenshot) GENERATES_SCREENSHOT=true ;;
			background) RUN_IN_BACKGROUND=true ;;
			error) GENERATES_EXECUTION_ERROR=true ;;
			*) command_scheme+="$component " ;;
		esac
	done
	command_scheme="${command_scheme//  / }"
	command_scheme="${command_scheme% }"
}

# requires path to page
# requires command
function generate_execution_mode {
	local page="${1}"
	local command="${2}"

	if [ -z "$command" ]
	then
		tput setaf $SEVERITY_HIGH
		echo "execution command not specified: $page"
		tput sgr0
		return 1
	fi

	generate_html_code begin language-bash
	echo "$command" >&3
	generate_html_code end
}

# requires path to source
function build_scheme {
	local source="$1"
	local scheme="$2"

	if [ "${CAPTURE_SCREENSHOT:-false}" == "true" ]
	then
		local output="${source%.*}.screenshot.png"
	else
		local output="${source%.*}.output.txt"
	fi

	local source_change_time=$(stat -c "%Y" "$source" 2>/dev/null)
	local output_change_time=$(stat -c "%Y" "$output" 2>/dev/null)

	local output_file_required=false
	local template
	if grep -wq 'output' <<< "$PAGE_TEMPLATE"
	then
		if ! [ -f "$output" ]
		then
			output_file_required=true
		fi
	else
		output_change_time=$source_change_time
	fi

	local headers="$(sed -n "/^${source##*/}/s/${source##*/}\s//p" < "${source%/*}/.index")"

	# build compilation scheme
	create_command_scheme "$scheme" "$source" "${headers:-}"

	local process_id=

	if [ "${output_file_required:-false}" == "true" ] \
		|| [ "${source_change_time:-0}" -gt "${output_change_time:-0}" ] \
		|| [ "${FORCE_OPTION:-false}" == "true" ]
	then
		echo "$command_scheme" >&2
		local execution_error="${source%.*}.execution.error.txt"

		if [ "${GENERATES_SCREENSHOT:-false}" == "true" ]
		then
			unset GENERATES_SCREENSHOT
			capture_screenshot "$source" 2>/dev/null
		else
			if [ "${GENERATES_EXECUTION_ERROR:-false}" == "true" ]
			then
				local quarantine_room
				local working_directory
				quarantine_room="$(mktemp -d)"
				if [ -d "$quarantine_room" ]
				then
					working_directory="$(pwd)"
					cd "$quarantine_room"
				else
					tput setaf $SEVERITY_HIGH
					echo "failed to isolate execution" >&2
					tput sgr0
				fi

				if [ "${RUN_IN_BACKGROUND:-false}" == "true" ]
				then
					if ! eval "$command_scheme 1> $output 2> $execution_error" &
					then
						process_id="$!"
						unset GENERATES_EXECUTION_ERROR
						tput setaf $SEVERITY_LOW
						echo "Intentional execution error: $1" >&2
						tput sgr0
					fi
				elif ! eval "$command_scheme &> $output"
				then
					process_id="$!"
					unset GENERATES_EXECUTION_ERROR
					tput setaf $SEVERITY_LOW
					echo "Intentional execution error: $1" >&2
					tput sgr0
				else
					process_id="$!"
				fi

				if [ -d "$quarantine_room" ]
				then
					cd "$working_directory"
					rm -d "$quarantine_room"
					unset working_directory
					unset quarantine_room
				fi
			else
				if [ "${RUN_IN_BACKGROUND:-false}" == "true" ]
				then
					if ! eval "$command_scheme 1> $output 2> $execution_error" &
					then
						process_id="$!"
						tput setaf $SEVERITY_HIGH
						echo "Execution error: $1" >&2
						echo "    Command: $command_scheme" >&2
						echo "    Reason: $execution_error" >&2
						tput sgr0
						return 1
					fi
				elif ! eval "$command_scheme 1> $output 2> $execution_error"
				then
					process_id="$!"
					tput setaf $SEVERITY_HIGH
					echo "Execution error: $1" >&2
					echo "    Command: $command_scheme" >&2
					echo "    Reason: $execution_error" >&2
					tput sgr0
					return 1
				else
					process_id="$!"
				fi
			fi

			if [ "${RUN_IN_BACKGROUND:-false}" == "true" ]
			then
				# wait for background process to finish in 30 seconds
				kill_process "$process_id" 30 &
				RUN_IN_BACKGROUND=false
			fi
		fi

		if ! [ -s "$execution_error" ]
		then
			rm "$execution_error"
		fi

		if ! [ -s "$output" ]
		then
			rm "$output"
		fi
	else
		tput setaf $SEVERITY_LOW
		echo "No changes since last execution: $1" >&2
		tput sgr0
		return 1
	fi
}

# requires path to page
# optional floor to start indexing directories
# sets page_index and page_hierarchy variables
function index_page {
	local floor="${2:-1}"

	local depth=1
	local entry=
	local hierarchy=
	local index=
	page_index=
	page_hierarchy=

	for entry in ${1//\//$'\n'}
	do
		hierarchy="${hierarchy:-$entry}"

		if [ "$depth" -gt "$floor" ]
		then
			match="$(grep -n "^$entry" "${hierarchy}/.index")"
			match="${match%%:*}"
			match="${match%% *}"

			if [ "${match:-0}" -gt 0 ]
			then
				((match--)) # shift index down because of readme indexes
			fi
			index+="${match:-0}."
		fi

		((depth++))
		hierarchy="${hierarchy}/${entry}"
	done
	page_index="${index%.}"
	page_hierarchy="${hierarchy#\.\/}"
}

# requires path to page
# optional up/down for direction of growth
# sets deepest_page variable
function deepest_path {
	local hierarchy="${1%/}"
	local direction="${2:-up}"

	local entry=
	local tool=
	deepest_page=

	if [ "$direction" = "up" ]
	then
		tool="head"
	elif [ "$direction" = "down" ]
	then
		tool="tail"
	else
		return 1
	fi

	while true
	do
		if [ -d "$hierarchy" ] && [ -f "${hierarchy}/.index" ]
		then
			entry="$("$tool" -n1 "${hierarchy}/.index")"
			entry="${entry%% *}"
			if [ -n "$entry" ]
			then
				hierarchy="${hierarchy}/${entry}"
			else
				break
			fi
		else
			break
		fi
	done
	deepest_page="$hierarchy"
}

# requires path to page
# optional up/down for direction of growth
# sets page_index and page_hierarchy variables
# note: empty variables means there is no neighbor
function nearest_path {
	local hierarchy="${1%/}"
	local page="${hierarchy##*/}"
	hierarchy="${hierarchy%/*}"
	local direction="${2:-up}"
	local match=
	local option=
	local first="true"

	if [ "$direction" = "up" ]
	then
		option="-B1"
	elif [ "$direction" = "down" ]
	then
		option="-A1"
	else
		return 1
	fi

	while [ "$hierarchy" != "." ] || [ "$first" = "true" ]
	do
		if [ "$hierarchy" = "." ]
		then
			first="false"
		fi

		match="$(grep "$option" "^$page" "${hierarchy}/.index")"

		if [ "$direction" = "up" ]
		then
			match="${match%$'\n'*}"
		else
			match="${match#*$'\n'}"
		fi
		match="${match%% *}"

		if [ "$match" = "$page" ]
		then
			page="${hierarchy##*/}"
			hierarchy="${hierarchy%/*}"
		else
			if [ "$direction" = "up" ]
			then
				direction="down"
			else
				direction="up"
			fi

			if [ -d "${hierarchy}/${match}" ]
			then
				deepest_path "${hierarchy}/${match}" "$direction"
				page="$deepest_page"
			else
				page="${hierarchy}/${match}"
			fi

			index_page "$page"
			break
		fi
	done
}

# zero-out badge variable before use
# requires path to chapter
function generate_group_badge {
	local entry=
	while read -r entry
	do
		if [ "$entry" = "README.md" ]
		then
			continue
		elif [ -d "${1%/*}/${entry%% *}" ]
		then
			generate_group_badge "${1%/*}/${entry}/.index"
		elif [ -f "${1%/*}/${entry%% *}" ]
		then
			((badge++))
		fi
	done < "$1"
}

# requies process id to kill
# requies seconds to wait before strike
function kill_process {
	sleep "$2"
	if [ "$(ps -ef | awk -v pid=$1 '$2 == pid {print $2}')" == "$1" ]
	then
		kill -s STOP "$1"
	fi
}

# requires source file
function capture_screenshot {
	local source="$1"
	local imagefile="${source%.*}.screenshot.png"

	local binary="${source%.*}${EXECUTABLE_EXTENSION:-.bin}"
	local process="${binary##*/}"

	if [ -f "$binary" ] && $binary &>/dev/null &
	then
		local lifetime=0
		local pid=

		while ! pid=$(pgrep "$process"); do
			if [ "$lifetime" -gt 50 ]
			then
				tput setaf $SEVERITY_HIGH
				echo "Screenshot session timed out: $source" >&2
				tput sgr0
				return 1
			fi
			sleep .1
			((lifetime++))
		done

		if gnome-screenshot --display :0 --file "$imagefile" --delay 1 --window &>/dev/null
		then
			if kill "$pid" &>/dev/null
			then
				tput setaf $SEVERITY_LOW
				echo "Screenshot captured: ${imagefile}" >&2
				tput sgr0
			else
				tput setaf $SEVERITY_HIGH
				echo "Failed to kill process after screenshot: $source" >&2
				tput sgr0
				rm -f "${source%.*}.screenshot.png"
				return 1
			fi
		else
			tput setaf $SEVERITY_HIGH
			echo "Screenshot tool (gnome-screenshot) failed to run: $source" >&2
			tput sgr0
			rm -f "${source%.*}.screenshot.png"
			return 1
		fi
	else
		tput setaf $SEVERITY_HIGH
		echo "Failed to run program for screenshot: $source" >&2
		tput sgr0
		rm -f "${source%.*}.screenshot.png"
		return 1
	fi
}

