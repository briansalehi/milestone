# required begin/end
# required source
function generate_html_head {
	local title="${2%.*}.title.txt"
	local content

	if [ "$1" == "begin" ]
	then
		if [ -f "$title" ]
		then
			content="$(cat "$title")"
		else
			tput setaf $SEVERITY_MEDIUM
			echo "Default title occupied: $title" >&2
			tput sgr0
		fi
	
		cat << EOF >&3
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
<title>${content:-"Notebook"}</title>
