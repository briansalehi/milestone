if [ -f ./.config ] && [ ./.index ]
then
	validation_check=202101202003
	source ./.config
	if [ "${VALIDATION_ID:-0}" -lt "$validation_check" ]
	then
		tput setaf $SEVERITY_LOW
		echo "configuring repository for the latest update..." >&2
		tput sgr0
		if ! validate_configuration "./.index"
		then
			echo "configuration failed"
			exit 1
		fi
		regenerate_configuration "./.config"
		extract_configuration "./.config"
		sed -i "s/^\(VALIDATION_ID=\)[0-9]*$/\1${validation_check}/" ./.config
		echo
		echo "configuration complete"
		echo "run again to continue"
		exit 0
	fi
fi

if [ $# -eq 0 ]
then
	# At least one .index must exist at current directory
	# Everything starts here
	generate_manuals "./.index"
else
	case "$1" in
		-h|--help) usage ;;
		-r|--remove) remove_files "${2%/}" ;;
		-o|--reorder) reorder_index "${2%/}" ;;
		-f|--force-compile) remove_outputs; generate_manuals "./.index" ;;
		*)
			if [ "${1:0:1}" = "-" ]
			then
				usage
			else
				if ! analyze_paramters "$1" "$2"
				then
					exit 1
				fi
			fi ;;
	esac
fi
