# requires path to page
function generate_source_section {
	if [ "${SOURCE:-false}" != "true" ]
	then
		return 1
	fi

	generate_html_breaker
	generate_html_header 3 "Source"
	while [ $# -gt 0 ]
	do
		generate_page_name "${1}"

		local syntax=
		if [ -n "$SYNTAX" ]
		then
			syntax="$SYNTAX"
		else
			syntax="${1##*.}"
		fi

		generate_html_code begin line-numbers "language-${syntax}"
		OLD_IFS="$IFS"
		IFS=
		local line
		while read -r line
		do
			line="${line//&/&amp;}"
			line="${line//\"/&quot;}"
			line="${line//\'/&apos;}"
			line="${line//</&lt;}"
			line="${line//>/&gt;}"
			echo "    $line" >> "./html-files/${index}.html"
		done < "$1"
		IFS="$OLD_IFS"
		generate_html_code end
		shift
	done
}

# requires absolute path to page
function generate_output_section {
	local page="${1%.*}"
	local binary="$page.bin"
	local output="${page}.output.txt"
	local compilation_error="$page.compilation.error.txt"
	local linkage_error="$page.linkage.error.txt"
	local runtime_error="$page.runtime.error.txt"
	local input="$page.input.txt"
	page="${page##*/}"
	local line

	if ! compile_source $@
	then
		return 1
	fi

	if ! run_program "$1" $@
	then
		return 1
	fi

	if [ "${INPUT:-false}" = "true" ] && [ -f "$input" ]
	then
		generate_html_breaker
		generate_html_header 3 Input
		generate_html_code begin language-bash

		while read -r line
		do
			echo "$line" >> "./html-files/${index}.html"
		done < "$input"

		generate_html_code end
	fi

	if [ "${OUTPUT:-false}" = "true" ]
	then
		if [ "${CAPTURE_SCREENSHOT:-false}" == "true" ]
		then
			generate_html_breaker
			generate_html_header 3 Output
			generate_page_name "${1%.*}.png"
			find_index_alias "$page_index"
			generate_html_screenshot "$1"
		elif [ -f "$output" ]
		then
			if [ "$(wc -w < "$output")" -gt 0 ]
			then
				generate_html_breaker
				generate_html_header 3 Output
				generate_html_code begin language-txt

				while read -r line
				do
					echo "$line" >> "./html-files/${index}.html"
				done < "$output"

				if [ "$(wc -l < "$output")" -eq 0 ]
				then
					echo >> "$output"
				fi

				generate_html_code end
			fi
		else
			tput setaf $SEVERITY_HIGH
			echo "output file not found: $output" >&2
			tput sgr0
		fi
	fi

	local generates_error="false"
	if [ "${GENERATES_COMPILATION_ERROR:-false}" = "true" ] || \
		[ "${GENERATES_LINKAGE_ERROR:-false}" = "true" ] || \
		[ "${GENERATES_RUNTIME_ERROR:-false}" = "true" ]
	then
		if [ -f "$compilation_error" ] || [ -f "$linkage_error" ] || [ -f "$runtime_error" ]
		then
			generate_html_breaker
			generate_html_header 3 Output
		fi
	fi

	if [ "${ERROR:-false}" = "true" ] && [ "${GENERATES_COMPILATION_ERROR:-false}" = "true" ]
	then
		if [ -f "$compilation_error" ]
		then
			if [ "$(wc -w < "$compilation_error")" -gt 0 ]
			then
				generate_html_breaker
				generate_html_header 3 Error
				generate_html_code begin language-bash

				while read -r line
				do
					echo "$line" >> "./html-files/${index}.html"
				done < "$compilation_error"

				if [ "$(wc -l < "$compilation_error")" -eq 0 ]
				then
					echo >> "$compilation_error"
				fi

				generate_html_code end
			fi
		else
			tput setaf $SEVERITY_HIGH
			echo "compilation error file wanted but not found: $compilation_error" >&2
			tput sgr0
		fi
	fi

	if [ "${ERROR:-false}" = "true" ] && [ "${GENERATES_LINKAGE_ERROR:-false}" = "true" ]
	then
		if [ -f "$linkage_error" ]
		then
			if [ "$(wc -w < "$linkage_error")" -gt 0 ]
			then
				generate_html_breaker
				generate_html_header 3 Error
				generate_html_code begin language-bash

				while read -r line
				do
					echo "$line" >> "./html-files/${index}.html"
				done < "$linkage_error"

				if [ "$(wc -l < "$linkage_error")" -eq 0 ]
				then
					echo >> "$linkage_error"
				fi

				generate_html_code end
			fi
		else
			tput setaf $SEVERITY_HIGH
			echo "linkage error file wanted but not found: $linkage_error" >&2
			tput sgr0
		fi
	fi

	if [ "${ERROR:-false}" = "true" ] && [ "${GENERATES_RUNTIME_ERROR:-false}" = "true" ]
	then
		if [ -f "$runtime_error" ]
		then
			if [ "$(wc -w < "$runtime_error")" -gt 0 ]
			then
				generate_html_breaker
				generate_html_header 3 Error
				generate_html_code begin language-bash

				while read -r line
				do
					echo "$line" >> "./html-files/${index}.html"
				done < "$runtime_error"

				if [ "$(wc -l < "$runtime_error")" -eq 0 ]
				then
					echo >> "$runtime_error"
				fi

				generate_html_code end
			fi
		else
			tput setaf $SEVERITY_HIGH
			echo "runtime error file wanted but not found: $runtime error" >&2
			tput sgr0
		fi
	fi
}

# requires absolute path to page
function generate_comment_section {
	if [ "$COMMENT" != "true" ]
