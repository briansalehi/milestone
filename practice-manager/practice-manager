# requires relative path to list
function expand_list {
	local directory
	local members
	local group

	directory="${1%/*}"

	if ! [ -f "$1" ]
	then
		tput setaf $SEVERITY_HIGH
		echo "unindexed directory: $directory/" >&2
		tput sgr0
		return 1
	fi

	local line
	while read -r line
	do
		members="${line//[^\ ]/}"

		if [ "${#members}" -gt 0 ]
		then
			for file in $line
			do
				if [ -f "$directory/$file" ]
				then
					group="$group $directory/$file"
				else
					tput setaf $SEVERITY_HIGH
					echo "missing group member: $directory/$file" >&2
					tput sgr0
					continue 2
				fi
			done
			generate_page $group
		elif [ -f "$directory/$line" ] && [ "$line" != "README.md" ]
		then
			generate_page "$directory/$line"
		elif [ -f "$directory/$line" ] && [ "$line" = "README.md" ]
		then
			generate_chapter "$directory/$line"
		elif [ -d "$directory/$line" ]
		then
			expand_list "$directory/$line/.index"
		else
			tput setaf $SEVERITY_HIGH
			echo "missing entry: $directory/$line" >&2
			tput sgr0
		fi
		group=
	done < "$1"
}

