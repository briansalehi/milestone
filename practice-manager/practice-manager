			local image="${match#*[}"
			image="${image%]*}"

			find_index_alias "$page_index"
			generate_html_image "$1" "$image" "$linenumber"
			sed -i "${linenumber}d" "./html-files/${index}.html"
		done
		generate_html_div "$1" end
	fi
}

# requires index
function find_index_alias {
	page_alias=

	if [ "$1" = "0" ]
	then
		return 0
	fi
	
	local alias_file=
	local alias=
	local location=
	local sourcefile=
	local entry=
	for entry in ${1//./ }
	do
		((entry++))
		if [ "$entry" = "0" ]
		then
			tput setaf $SEVERITY_HIGH
			echo "invalid index number: $1 => $location"
			tput sgr0
			return 1
		fi

		if [ -z "$location" ]
		then
			sourcefile="$(sed -n "${entry}p" ".index")"
			location="${sourcefile%% *}"
		else
			sourcefile="$(sed -n "${entry}p" "${location}/.index")"
			location="${location}/${sourcefile%% *}"
		fi

		if [ -d "$location" ]
		then
			alias_file="${location}/README.alias.txt"
		elif [ -f "$location" ]
		then
			if [ "$entry" = "1" ]
			then
				continue
			fi
			alias_file="${location%.*}.alias.txt"
		else
			tput setaf $SEVERITY_HIGH
			echo "invalid index for aliasing: ${1} => ${location}"
			tput sgr0
			return 1
		fi

		if [ -f "$alias_file" ] && [ "$(wc -m < "$alias_file")" -gt 0 ]
		then
			alias="${alias}/$(cat "$alias_file")"

			if [ "$entry" = "0" ]
			then
				alias="${alias}/index"
			fi
		else
			return 1
		fi
	done

	page_alias="$alias"
}

# requires absolute path to page
function generate_quick_access_section {
	local page="${1%.*}"
	page="${page##*/}"
	local current_index=
	local next_index=
	local previous_index=
	local button=

	index_page "$1"
	current_index="$page_index"

	nearest_path "$1" up
	if [ "$page_index" = "$current_index" ]
	then
		previous_index=
	else
		previous_index="$page_index"
	fi

	nearest_path "$1" down
	if [ "$page_index" = "$previous_index" ]
	then
		next_index=
	else
		next_index="$page_index"
	fi

	generate_html_list begin pager

	find_index_alias "${previous_index:-0}"

	button="previous page"
	if [ -n "$previous_index" ]
	then
		previous_index="${previous_index}.html"
		generate_html_item_with_link "$button" "${page_alias:-$previous_index}" previous "B"
	else
		generate_html_item_with_link "$button" "#" "previous disabled"
	fi

	button="top page"
	if [ -z "$previous_index" ] || [ -z "$next_page" ]
	then
		generate_html_item_with_link "$button" "/" top "T"
	fi

	find_index_alias "${next_index:-0}"

	button="next page"
	if [ -n "$next_index" ]
	then
		next_index="${next_index}.html"
		generate_html_item_with_link "$button" "${page_alias:-$next_index}" next "F"
	else
		generate_html_item_with_link "$button" "#" "next disabled"
	fi

	generate_html_list end
}

function generate_table_of_content {
	local hierarchy="${1%/*}"
	local heading="${2:-false}"
	local nest="${3:-1}"
	local entry=
	local indentation=
	local local_index=
	local title=
	local page_link=

	while read -r entry
	do
		entry="${entry%% *}"
		if [ -d "${hierarchy}/${entry}" ] || [ "$entry" = "README.md" ]
		then
			if [ "$entry" = "README.md" ]
			then
				index_page "${hierarchy}/${entry}"
				if [ "$page_index" = "0" ] || [ "$heading" == "true" ]
				then
					heading="false"
					#title="$(cat "${hierarchy}/${entry%.*}.title.txt")"
					#generate_html_header_with_link "$1" 3 "$title" "${page_index}.html"
					generate_html_breaker
					generate_html_header 3 "Table of Content"
					generate_list_group_root "$1" begin
				else
