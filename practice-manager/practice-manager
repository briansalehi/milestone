# required functions for managing practice pages
###############################################################################

# requires path to page
function extract_configuration {
	if [ -f "${1%.*}.config" ]
	then
		sed -i 's/^#\([^#]\)/\1/' "${1%.*}.config"
	fi
}

# requires absolute path to page
function generate_configuration {
	local page

	if [ -f "$1" ]
	then
		page="${1%.*}.config"
	elif [ -d "$1" ]
	then
		page="${1%/}/.config"
	else
		tput setaf $SEVERITY_HIGH
		echo "invalid location to create config file: $1" >&2
		tput sgr0
		return 1
	fi

	cat << EOF > "$page"
$main_configuration
EOF
}

# requires path to config
function regenerate_configuration {
	if [ "${1##*.}" != "config" ]
	then
		tput setaf $SEVERITY_HIGH
		echo "invalid configuration to regenerate"
		tput sgr0
		return 1
	elif ! [ -f "$1" ]
	then
		touch "$1"
	fi

	local line=
	local config=
	local value=
	local target_config="$(grep '^[^# ]' "$1")"

	generate_configuration "$1"

	while read -r line
	do
		config="${line%%=*}" # read configuration name
		value="${line#*=}" # read configuration value
		value="${value%%#*}" # ignore inline comments

		# backward compatibility section
		# if configs name are changed, map their values into new ones
		case "$config" in
			GENERATES_ERROR) config="GENERATES_RUNTIME_ERROR" ;;
			LANGUAGE) config="SYNTAX" ;;
			CHAPTER_TEMPLATE)
				if [ "$validation_check" == "202012271813" ] && [ "$(grep "toc" <<< "$value")" == "" ]
				then
					value="${value%\"} toc\""
				fi ;;
		esac

		sed -i "/^#${config}=/s/^#\(${config}\)=.*/\1=${value}/" "$1"
	done <<< "$target_config"
}

# requires path to page
function validate_page {
	local page=
	local extension=

	for extension in alias.txt title.txt comment.txt reference.txt config
	do
		page="${1%.*}.${extension}"

		if ! [ -f "$page" ]
		then
			if [ "$extension" = "config" ]
			then
				generate_configuration "$1"
			else
				touch "$page"
			fi
		else
			if [ "$extension" = "config" ]
			then
				regenerate_configuration "$page"
			fi
		fi
	done
}

# requires path to chapter
function validate_chapter {
	local page=
	local extension=

	if ! [ -f "${1%/}/.index" ]
	then
		echo "README.md" > "${1%/}/.index"
	elif [ "$(head -n1 "${1%/}/.index")" != "README.md" ]
	then
		sed -i -e '/README.md/d' -e '1i README.md' "${1%/}/.index"
	fi

	# update configuration of chapter
	regenerate_configuration "${1%/}/.config"

	for extension in md config alias.txt title.txt comment.txt reference.txt
	do
		page="${1%/}/README.${extension}"

		if [ "$extension" = "config" ]
		then
			# configuration for readme file
			echo "EXECUTABLE=false" > "$page"
			echo "SOURCE=false" >> "$page"
			echo "INPUT=false" >> "$page"
			echo "OUTPUT=false" >> "$page"
			# update configuration of readme
			regenerate_configuration "$page"
		elif ! [ -f "$page" ]
		then
			if [ "$extension" = "md" ]
			then
				echo -e "# Milestone Notebooks\n" > "$page"
				echo -n "This file is automatically created by " >> "$page"
				echo -n "<b>Practice Manager</b> " >> "$page"
				echo -n "and is part of the " >> "$page"
			   	echo -n "<a href=\"https://github.com/briansalehi/milestone.git\">" >> "$page"
				echo -n "<b>Milestone</b></a> project." >> "$page"
			else
				touch "$page"
			fi
		fi
	done
}

# requires relative path to list
function validate_configuration {
	local directory="${1%/*}"
	local members
	local line
	local file

	if ! [ -f "$1" ]
	then
		tput setaf $SEVERITY_HIGH
		echo "unindexed directory: $directory/" >&2
		tput sgr0
		return 1
	fi

	while read -r line
	do
		line="${line%% *}"
		if [ -f "$directory/$line" ]
		then
			validate_page "$directory/$line"
		elif [ -d "$directory/$line" ]
		then
			validate_chapter "$directory/$line"
			if ! validate_configuration "$directory/$line/.index"
			then
				return 1
			fi
		else
			tput setaf $SEVERITY_HIGH
			echo "missing entry: $directory/$line" >&2
			tput sgr0
		fi
	done < "$1"
}

# requires absolute path to source to configure corresponding variables
function update_configuration {
	local directory
	local config

	for level in ${1//\//$'\n'}
	do
		if [ -d "$directory$level" ]
		then
			directory="$directory$level/"
		elif [ -f "$directory$level" ]
		then
			directory="$directory${level%.*}"
		fi

		config="$directory.config"

		if [ -f "$config" ]
		then
			source "$config"
		fi
	done
}

# requires scheme
# requires page name
function create_command_scheme {
	local scheme="$1"
	local page="$2"
	local headers="$3"
	local component
	command_scheme=

	for component in $scheme
	do
		case "$component" in
			compiler) command_scheme+="$COMPILER " ;;
			compiler_options) command_scheme+="$COMPILER_OPTIONS " ;;
			linker) command_scheme+="$LINKER " ;;
			linker_options) command_scheme+="$LINKER_OPTIONS " ;;
			running_options) command_scheme+="$RUNNING_OPTIONS " ;;
			object) command_scheme+="${source%.*}.${OUTPUT_OBJECT:-o} " ;;
			source) command_scheme+="${source} " ;;
			binary) command_scheme+="${source%.*}.bin " ;;
			headers) command_scheme+="$headers " ;;
			page|pagename|rawname) command_scheme+="${source%.*} " ;;
			location) command_scheme+="${source%/*} " ;;
			makefile) local makefile="${source%.*}.make"; command_scheme+="${makefile##*/} " ;;
			extension-*) command_scheme+="${source%.*}.${component#extenion-} " ;;
			*) command_scheme+="$component " ;;
		esac
	done
	command_scheme="${command_scheme//  / }"
	command_scheme="${command_scheme% }"
}

# requires path to page
# requires compile/link/run option
# requires command
# optional syntax
function generate_execution_mode {
	local page="${1}"
	local mode="${2:-compile}"
	local command="${3}"
	local syntax="${4:-practices}"

	if [ -z "$command" ]
	then
		tput setaf $SEVERITY_HIGH
		echo "execution command not specified for ${mode}: $page"
		tput sgr0
		return 1
	fi

	generate_html_header 4 "${mode}"
	generate_html_code begin command-line language-bash #"data-user=\"${syntax}\" data-host=\"milestone\""
	echo "$command" >> "./html-files/${index}.html"
	generate_html_code end
}

# requires absolute path to source
# option headers and required files
function compile_source {
	local source="$1"
	local page="${1%.*}"
	page="${page##*/}"
	local location="${1%/*}"

	if [ "${EXECUTABLE:-false}" != "true" ]
	then
		return 1
	fi

	local syntax=
	if [ -n "$SYNTAX" ]
	then
		syntax="$SYNTAX"
	else
		syntax="${1##*.}"
	fi

	generate_html_breaker
	generate_html_header 3 "Execution"

	local binary="${1%.*}.bin"
	OUTPUT_OBJECT="${OUTPUT_OBJECT:-o}"
	local object="${1%.*}.${OUTPUT_OBJECT#.}"
	local headers="$@"
	headers="${headers/$1 }"
	local includes=
	local output="${1%.*}.output.txt"
	local compilation_error="${1%.*}.compilation.error.txt"
	local linkage_error="${1%.*}.linkage.error.txt"
	local output_change_time
	local source_change_time
	local component=

	if [ "${COMPILABLE:-false}" = "true" ] && [ -z "$COMPILER" ]
	then
		tput setaf $SEVERITY_HIGH
		echo "compiler not specified for: $1" >&2
		tput sgr0
		return 1
	fi

	if [ "${INCLUDES:-false}" != "true" ]
	then
		headers=
	fi

	if [ "${CAPTURE_SCREENSHOT:-false}" == "true" ]
	then
		output="${1%.*}.screenshot.png"
	else
		output="${1%.*}.output.txt"
	fi

	source_change_time=$(stat -c "%Y" "$1")

	if [ -f "$output" ]
	then
		output_change_time=$(stat -c "%Y" "$output")
	else
		output_change_time=0
	fi

	# build compilation scheme
	create_command_scheme "${COMPILATION_SCHEME/options/compiler_options}" "$source" "$headers"
	local compilation_command="$command_scheme"

	# build post compilation scheme
	create_command_scheme "${POST_COMPILATION_SCHEME/optionos/compiler_options}" "$source" "$headers"
	local post_compilation_command="$command_scheme"

	if ! [ -f "$output" ] || [ "$source_change_time" -gt "$output_change_time" ]
	then
		if [ "${COMPILABLE:-false}" = "true" ]
		then
			if ! $compilation_command &> "$compilation_error"
			then
				if [ "${GENERATES_COMPILATION_ERROR:-false}" != "true" ]
				then
					tput setaf $SEVERITY_HIGH
					echo "compilation error: $1" >&2
					echo "  command: $compilation_command" >&2
					tput sgr0
					return 1
				fi
			fi

			if [ -n "$post_compilation_command" ] && ! $post_compilation_command &>> "$compilation_error"
			then
				if [ "${GENERATES_COMPILATION_ERROR:-false}" != "true" ]
				then
					tput setaf $SEVERITY_HIGH
					echo "post compilation error: $1" >&2
					echo "  command: $post_compilation_command" >&2
					tput sgr0
					return 1
				fi
			fi

			if [ "${GENERATES_COMPILATION_ERROR:-false}" != "true" ] || [ "$(wc -w < "$compilation_error")" -eq 0 ]
			then
				rm "$compilation_error"
			fi
		elif [ "${LINKABLE:-false}" = "true" ]
		then
			if [ -f "$binary" ]
			then
				unlink "$binary"
			fi
			ln -s "$PWD/${1/\.\//}" "${binary}"
		fi
	fi

	if [ "${COMPILABLE:-false}" = "true" ]
	then
		compilation_command="${compilation_command//$location\//}"
		generate_execution_mode "$1" compile "$compilation_command" "$syntax"
	fi

	# build linkage scheme
	create_command_scheme "${LINKAGE_SCHEME/options/linker_options}" "$source" "$headers"
	local linkage_command="$command_scheme"

	if [ "${LINKABLE:-false}" = "true" ] && ! [ -f "$output" ]\
	   	|| [ "$source_change_time" -gt "$output_change_time" ]
	then
		if [ "${LINKABLE:-false}" = "true" ] && [ -n "$LINKER" ]
		then
			if ! $linkage_command 2> "$linkage_error"
			then
				if [ "${GENERATES_LINKAGE_ERROR:-false}" != "true" ]
				then
					tput setaf $SEVERITY_HIGH
					echo "linkage error for: $1" >&2
					echo "  command: $linkage_command" >&2
					tput sgr0
					return 1
				fi
			fi

			if [ "${GENERATES_LINKAGE_ERROR:-false}" != "true" ] || [ "$(wc -w < "$linkage_error")" -eq 0 ]
			then
				rm "$linkage_error"
			fi
		elif [ "${LINKABLE:-false}" = "true" ] && [ -z "$LINKER" ]
		then
			tput setaf $SEVERITY_HIGH
			echo "linker not specified for: $1" >&2
			tput sgr0
			return 1
		fi
	fi

	if [ "${LINKABLE:-false}" = "true" ]
	then
		linkage_command="${linkage_command//$location\//}"
		generate_execution_mode "$1" link "$linkage_command" "$syntax"
	fi
}

# requires path to page
# optional floor to start indexing directories
# sets page_index and page_hierarchy variables
function index_page {
	local floor="${2:-1}"

	local depth=1
	local entry=
	local hierarchy=
	local index=
	page_index=
	page_hierarchy=

	for entry in ${1//\//$'\n'}
	do
		hierarchy="${hierarchy:-$entry}"

		if [ "$depth" -gt "$floor" ]
		then
			match="$(grep -n "^$entry" "${hierarchy}/.index")"
			match="${match%%:*}"
			match="${match%% *}"

			if [ "${match:-0}" -gt 0 ]
			then
				((match--)) # shift index down because of readme indexes
			fi
			index+="${match:-0}."
		fi

		((depth++))
		hierarchy="${hierarchy}/${entry}"
	done
	page_index="${index%.}"
	page_hierarchy="${hierarchy#\.\/}"
}

# requires path to page
# optional up/down for direction of growth
# sets deepest_page variable
function deepest_path {
	local hierarchy="${1%/}"
	local direction="${2:-up}"

	local entry=
	local tool=
	deepest_page=

	if [ "$direction" = "up" ]
	then
		tool="head"
	elif [ "$direction" = "down" ]
	then
		tool="tail"
	else
		return 1
	fi

	while true
	do
		if [ -d "$hierarchy" ] && [ -f "${hierarchy}/.index" ]
		then
			entry="$("$tool" -n1 "${hierarchy}/.index")"
			entry="${entry%% *}"
			if [ -n "$entry" ]
			then
				hierarchy="${hierarchy}/${entry}"
			else
				break
			fi
		else
			break
		fi
	done
	deepest_page="$hierarchy"
}

# requires path to page
# optional up/down for direction of growth
# sets page_index and page_hierarchy variables
# note: empty variables means there is no neighbor
function nearest_path {
	local hierarchy="${1%/}"
	local page="${hierarchy##*/}"
	hierarchy="${hierarchy%/*}"
	local direction="${2:-up}"
	local match=
	local option=
	local first="true"

	if [ "$direction" = "up" ]
	then
		option="-B1"
	elif [ "$direction" = "down" ]
	then
		option="-A1"
	else
		return 1
	fi

	while [ "$hierarchy" != "." ] || [ "$first" = "true" ]
	do
		if [ "$hierarchy" = "." ]
		then
			first="false"
		fi

		match="$(grep "$option" "^$page" "${hierarchy}/.index")"

		if [ "$direction" = "up" ]
		then
			match="${match%$'\n'*}"
		else
			match="${match#*$'\n'}"
		fi
		match="${match%% *}"

		if [ "$match" = "$page" ]
		then
			page="${hierarchy##*/}"
			hierarchy="${hierarchy%/*}"
		else
			if [ "$direction" = "up" ]
			then
				direction="down"
			else
				direction="up"
			fi

			if [ -d "${hierarchy}/${match}" ]
			then
				deepest_path "${hierarchy}/${match}" "$direction"
				page="$deepest_page"
			else
				page="${hierarchy}/${match}"
			fi

			index_page "$page"
			break
		fi
	done
}

# zero-out badge variable before use
# requires path to chapter
function generate_group_badge {
	local entry=
	while read -r entry
	do
		if [ "$entry" = "README.md" ]
		then
			continue
		elif [ -d "${1%/*}/${entry%% *}" ]
		then
			generate_group_badge "${1%/*}/${entry}/.index"
		elif [ -f "${1%/*}/${entry%% *}" ]
		then
			((badge++))
		fi
	done < "$1"
}

# requies process id to kill
# requies seconds to wait before strike
function process_kill {
	sleep "$2"
	kill -SIGTERM "$1"
}

# requires source file
function capture_screenshot {
	local source="$1"
	local imagefile="${source%.*}.screenshot.png"

	local binary="${source%.*}"
	binary="${binary##*/}"

	if [ -f "${source%.*}.bin" ] && ${source%.*}.bin &>/dev/null &
	then
		local lifetime=0
		local pid=

		while ! pid=$(pgrep "$binary"); do
			if [ "$lifetime" -gt 50 ]
			then
				tput setaf $SEVERITY_HIGH
				echo "screenshot session timed out: $source"
				tput sgr0
				return 1
			fi
			sleep .1
			((lifetime++))
		done

		if gnome-screenshot --display :0 --file "$imagefile" --delay 1 --window &>/dev/null
		then
			if kill "$pid" &>/dev/null
			then
				tput setaf $SEVERITY_LOW
				echo "screenshot captured: ${imagefile}"
				tput sgr0
			else
				tput setaf $SEVERITY_HIGH
				echo "failed to kill process after screenshot: $source"
				tput sgr0
				rm -f "${source%.*}.screenshot.png"
			fi
		else
			tput setaf $SEVERITY_HIGH
			echo "screenshot tool (gnome-screenshot) failed to run: $source"
			tput sgr0
			rm -f "${source%.*}.screenshot.png"
		fi
	else
		tput setaf $SEVERITY_HIGH
		echo "failed to run program for screenshot: $source"
		tput sgr0
		rm -f "${source%.*}.screenshot.png"
	fi
}

# requires path to page
function run_program {
	local source="$1"
	OUTPUT_OBJECT="${OUTPUT_OBJECT:-o}"
	local object="${1%.*}.${OUTPUT_OBJECT#.}"
	local headers="$@"
	headers="${headers/$1 }"
	local output=

	local location="${1%/*}"
	local component=
	local source_change_time=
	local output_change_time=

	source_change_time=$(stat -c "%Y" "$1")

	if [ "${CAPTURE_SCREENSHOT:-false}" == "true" ]
	then
		output="${1%.*}.screenshot.png"
	else
		output="${1%.*}.output.txt"
	fi

	local runtime_error="${1%.*}.runtime.error.txt"
	if [ -f "$output" ]
	then
		output_change_time=$(stat -c "%Y" "$output")
	else
		output_change_time=0
	fi

	# build running scheme
	create_command_scheme "${RUNNING_SCHEME/options/running_options}" "$source" "$headers"
	local running_command="$command_scheme"

	if [ "${RUNNABLE:-false}" = "true" ]
	then
		if [ "${OUTPUT:-false}" = "true" ] && [ "$source_change_time" -gt "$output_change_time" ]
		then
			if [ "${CAPTURE_SCREENSHOT:-false}" == "true" ]
			then
				capture_screenshot "$source" 2>/dev/null
			elif [ -f "$input" ]
			then
				if ! $running_command < "$input" 2> "$runtime_error" 1> "$output"
				then
					if [ "${GENERATES_RUNTIME_ERROR:-false}" != "true" ]
					then
						tput setaf $SEVERITY_HIGH
						echo "running program failed: $source" >&2
						echo "  command: $running_command" >&2
						tput sgr0
					fi
				fi
				# remove empty or unwanted error files
				if [ "${GENERATES_RUNTIME_ERROR:-false}" != "true" ] || [ "$(wc -w < "$runtime_error")" -eq 0 ]
				then
					rm "$runtime_error"
				fi
			else
				if ! $running_command 2> "$runtime_error" 1> "$output"
				then
					if [ "${GENERATES_RUNTIME_ERROR:-false}" != "true" ]
					then
						tput setaf $SEVERITY_HIGH
						echo "running program failed: $source" >&2
						echo "  command: $running_command" >&2
						tput sgr0
					fi
				fi
				# remove empty or unwanted error files
				if [ "${GENERATES_RUNTIME_ERROR:-false}" != "true" ] || [ "$(wc -w < "$runtime_error")" -eq 0 ]
				then
					rm "$runtime_error"
				fi
			fi
		fi

		running_command="${running_command//$location\//./}"
		generate_execution_mode "$1" run "$running_command" "$SYNTAX"
	fi
}

