# requires path to page
function generate_reference_section {
	local reference="${1%.*}.reference.txt"

	if ! [ -f "$reference" ] || [ "$(wc -w < "$reference")" -eq 0 ]
	then
		tput setaf "$SEVERITY_MEDIUM"
		echo "reference not specified: $1" >&2
		tput sgr0
		return 1
	fi

	generate_html_breaker
	generate_html_header 3 "References"
	generate_html_list begin list-group

	local line
	while read -r line
	do
		generate_html_item "$line" list-group-item
	done < "$reference"

	generate_html_list end
}

# requires path to page
function generate_navigation_section {
	local hierarchy=
	local entry=
	local page=
	local title=
	local local_index=
	local depth=1

	generate_html_ordered_list "$1" begin breadcrumb
	generate_html_item_with_link "Home" "/" breadcrumb-item "$depth"
	((depth++))

	for entry in ${1//\//$'\n'}
	do
		if [ -z "$hierarchy" ]
		then
			hierarchy="$entry"
			continue
		fi

		hierarchy="${hierarchy}/${entry}"

		if [ -d "$hierarchy" ] && [ -f "${hierarchy}/README.title.txt" ]
		then
			if [ "${hierarchy}/README.md" != "$1" ]
			then
				title="$(cat "${hierarchy}/README.title.txt")"
				local_index="$hierarchy"
				local_index="${local_index//[^\/]/}"
				local_index="${#local_index}"
				page="$(cut -d"." -f1-"$local_index" <<< "$page_index").0.html"
				generate_html_item_with_link "${title:-"..."}" "$page" breadcrumb-item "$depth"
				((depth++))
			fi
		elif [ -f "$hierarchy" ] && [ -f "${hierarchy%.*}.title.txt" ]
		then
			title="$(cat "${hierarchy%.*}.title.txt")"
			generate_html_item "${title:-"..."}" "breadcrumb-item active"
		else
			tput setaf $SEVERITY_HIGH
			echo "untitled breadcrumb: ${hierarchy}"
			tput sgr0
			generate_html_item "..." breadcrumb-item
		fi
	done

	generate_html_ordered_list "$1" end
}

